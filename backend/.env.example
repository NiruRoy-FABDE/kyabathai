# ============================================================================
#  kyabathai backend — environment variables
#  Copy this file to ".env" for local dev, OR paste each value into Render →
#  your service → Environment. NEVER commit the real .env to GitHub.
# ============================================================================

# --- Database (Supabase → Project Settings → Database → Connection string) ---
# Use the "Session" / direct connection URL. Looks like:
#   postgresql://postgres:[PASSWORD]@db.lnbwqctcdwthpggrxukp.supabase.co:5432/postgres
# This is the SERVICE connection (bypasses RLS so the backend can write).
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.lnbwqctcdwthpggrxukp.supabase.co:5432/postgres

# --- Claude AI (console.anthropic.com → API Keys). Stays on the server only. ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-6

# --- YouTube Data API v3 (console.cloud.google.com → enable "YouTube Data API v3") ---
# Free quota: ~10,000 units/day, plenty for hourly trending pulls.
YOUTUBE_API_KEY=

# --- News (pick ONE; leave the other blank). ---
# NewsAPI.org  free tier:  https://newsapi.org/register
NEWSAPI_KEY=
# GNews.io     free tier:  https://gnews.io/  (used only if NEWSAPI_KEY is empty)
GNEWS_KEY=

# --- Region / language for trending pulls ---
REGION_CODE=IN
NEWS_COUNTRY=in

# --- Security ---
# A long random string. The /api/ingest endpoint requires it so randoms can't
# spam your Claude key. Generate one: python -c "import secrets;print(secrets.token_urlsafe(32))"
INGEST_SECRET=change-me-to-a-long-random-string

# Comma-separated list of sites allowed to call this API (your real domains).
CORS_ORIGINS=https://kyabathai.com,https://www.kyabathai.com,http://localhost:5173

# How many items each trending pull should try to fetch
INGEST_VIDEO_COUNT=15
INGEST_NEWS_COUNT=15
